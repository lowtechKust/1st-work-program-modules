<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Работа с атрибутами</title>
</head>
<body>

    <h1 id="title">Привет!</h1>

    <p>Абзац 1</p>
    <p>Абзац 2</p>
    <p>Абзац 3</p>

    <!-- Создаем ссылку с ID, чтобы было удобно к ней обратиться -->
    <a id="myLink">Перейти</a>

    <script>
        document.getElementById('title').textContent = "Добро пожаловать!";

        const paragraphs = document.querySelectorAll('p');
        alert("Количество абзацев: " + paragraphs.length);

        const link = document.getElementById('myLink');
        
        link.setAttribute('href', 'https://google.com');
        
        link.setAttribute('target', '_blank');
        
        link.style.color = 'blue';
        link.style.textDecoration = 'underline';
        link.style.cursor = 'pointer';
    </script>

</body>
</html>

