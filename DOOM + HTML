<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Работа с изображениями</title>
</head>
<body>

    <h1 id="title">Привет!</h1>

    <p>Абзац 1</p>
    <p>Абзац 2</p>
    <p>Абзац 3</p>

    <a id="myLink">Перейти</a>
    
    <hr>

    <img id="myImage" src="initial_placeholder.jpg" alt="Начальное изображение" width="200">

    <script>
        document.getElementById('title').textContent = "Добро пожаловать!";
        const paragraphs = document.querySelectorAll('p');
        alert("Количество абзацев: " + paragraphs.length);
        
        const link = document.getElementById('myLink');
        link.setAttribute('href', 'https://google.com');
        link.setAttribute('target', '_blank');
        
        // Стилизация первого абзаца
        paragraphs[0].style.color = 'red';
        paragraphs[0].style.fontSize = '20px';

        const imageElement = document.getElementById('myImage');
        
        const newImageUrl = 'https://via.placeholder.com/200x150/0000FF/FFFFFF?text=Новая+Картинка';
        
        imageElement.setAttribute('src', newImageUrl);

        imageElement.setAttribute('alt', 'Загружено новое изображение');
        
    </script>

</body>
</html>
