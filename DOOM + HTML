<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ссылка с JavaScript</title>
</head>
<body>
    <a id="myLink">Перейти</a>

    <script>
        // Получаем ссылку по идентификатору
        const link = document.getElementById("myLink");
        // Добавляем атрибуты href и target
        link.href = "https://google.com";
        link.target = "_blank"; // Открытие ссылки в новой вкладке
    </script>
</body>
</html>
