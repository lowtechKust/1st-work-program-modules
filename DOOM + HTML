<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Работа с элементами</title>
</head>
<body>

    <h1 id="title">Привет!</h1>

    <!-- Добавляем три абзаца -->
    <p>Первый абзац</p>
    <p>Второй абзац</p>
    <p>Третий абзац</p>

    <script>
        const headingElement = document.getElementById('title');
        headingElement.textContent = "Добро пожаловать!";

        const paragraphs = document.querySelectorAll('p');

        alert("Количество абзацев на странице: " + paragraphs.length);
    </script>

</body>
</html>

