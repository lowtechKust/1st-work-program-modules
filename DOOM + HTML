<!DOCTYPE html>
<html lang="ru">
<head>
 <meta charset="UTF-8">
 <meta name="viewport" content="width=device-width, initial-scale=1.0">
 <title>Подсчет параграфов</title>
</head>
<body>
 <h1 id="title">Привет!</h1>
 <p>Первый параграф.</p>
 <p>Второй параграф.</p>
 <p>Третий параграф.</p>

 <script>
   // Получаем все параграфы на странице
   const paragraphs = document.getElementsByTagName("p");
   // Выводим количество параграфов в alert
   alert("Количество параграфов: " + paragraphs.length);
 </script>
</body>
</html>

